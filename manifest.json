{
  "manifest_version": 3,
  "name": "Currency Converter",
  "version": "1.1.0",
  "description": "Convert currencies directly from context menu when you highlight amounts on web pages",

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "https://v6.exchangerate-api.com/*",
    "http://data.fixer.io/*",
    "https://data.fixer.io/*",
    "https://api.currencyapi.com/*",
    "https://www.alphavantage.co/*",
    "https://api.currencylayer.com/*",
    "https://openexchangerates.org/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Currency Converter Settings",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },

  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests;"
  }
}
