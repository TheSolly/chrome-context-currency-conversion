{
  "name": "currency-converter-extension",
  "version": "1.1.2",
  "description": "Chrome extension for real-time currency conversion through context menu",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "generate-icons": "node assets/icons/generate-icons.js",
    "build-css": "tailwindcss -i ./popup/styles.css -o ./popup/popup.css --watch",
    "build-css:prod": "tailwindcss -i ./popup/styles.css -o ./popup/popup.css --minify",
    "lint": "eslint . --ext .js --ignore-pattern dist/",
    "lint:fix": "eslint . --ext .js --fix --ignore-pattern dist/",
    "format": "prettier --write '**/*.{js,json,html,css,md}' --ignore-path .gitignore",
    "format:check": "prettier --check '**/*.{js,json,html,css,md}' --ignore-path .gitignore",
    "check": "yarn lint && yarn format:check",
    "fix": "yarn lint:fix && yarn format",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare-dev": "yarn generate-icons && yarn build-css:prod",
    "build:prod": "yarn check && yarn build-css:prod && yarn build"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0",
    "@eslint/js": "^9.28.0",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.8",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
